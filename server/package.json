{
  "name": "dmxr-server",
  "version": "1.3.1",
  "description": "DMXr bridge server — receives fixture color data via HTTP and outputs DMX",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest run --config vitest.config.ui.ts",
    "test:ui:watch": "vitest --config vitest.config.ui.ts",
    "test:ui:update": "UPDATE_BASELINES=1 vitest run --config vitest.config.ui.ts",
    "test:contract": "vitest run --config vitest.config.contract.ts",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.0",
    "better-sqlite3": "^12.8.0",
    "bonjour-service": "^1.3.0",
    "dmx-ts": "0.4.0",
    "fastify": "^5.8.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "@vitest/coverage-v8": "^4.1.3",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.40.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
